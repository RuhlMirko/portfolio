---
import * as Icons from "simple-icons";
import projects from "../data/projects.json";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Map tech names to simple-icons keys
const iconMap: Record<string, any> = {
  react: Icons.siReact,
  javascript: Icons.siJavascript,
  "node.js": Icons.siNodedotjs,
  astro: Icons.siAstro,
  typescript: Icons.siTypescript,
  css: Icons.siCss,
};

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/thumbnails/*.{png,jpg,jpeg,webp,avif}",
  { eager: true },
);

const imageMap: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(imageModules).map(([path, module]) => {
    const fileName = path.split("/").pop() ?? "";
    const key = fileName.replace(/\.[^.]+$/, "");
    return [key, module.default];
  }),
);
---

<section id="projects">
  <h2>Projects</h2>
  <hr />
  <div class="projects-container">
    {
      projects.projects.map((project) => (
        <div class="card">
          <header>
            <div class="card-media">
              {imageMap[project.thumbnail] ? (
                <Image src={imageMap[project.thumbnail]} alt={project.title} />
              ) : (
                <div class="thumbnail-fallback" aria-hidden="true" />
              )}
            </div>
            <h3>{project.title}</h3>
          </header>
          <main>
            <p class="project-description">
              {project.description.split("\n").map((line) => (
                <span class="desc-line">{line}</span>
              ))}
            </p>
            <ul class="tech-stack">
              {project.tech.map((tech) => {
                const icon = iconMap[tech];
                return icon ? (
                  <li>
                    <span class="tech-pill">
                      <svg
                        role="img"
                        viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                      >
                        <path d={icon.path} fill="currentColor" />
                      </svg>
                      {icon.title}
                    </span>
                  </li>
                ) : null;
              })}
            </ul>
          </main>
          <footer>
            {project.demo && (
              <a href={project.demo} target="_blank">
                Live demo
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M15 3h6v6" />
                  <path d="M10 14 21 3" />
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                </svg>
              </a>
            )}
            <a href="">
              View code
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d={Icons.siDiscord.path} fill="currentColor" />
              </svg>
            </a>
          </footer>
        </div>
      ))
    }
  </div>
</section>
<style>
  section {
    margin-top: 8vh;
  }

  .projects-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .project-description {
    text-wrap: pretty;
    max-width: 45ch;
    margin: 0.5rem auto 1rem;
    line-height: 1.1;
  }
  .desc-line {
    display: block;
  }
  .desc-line + .desc-line {
    margin-top: 0.35rem;
  }

  h3 {
    color: #dad9d99d;
    transition: color 0.2s;
  }
  .card {
    width: 100%;
    min-width: 300px;
    min-height: 200px;
    margin: 0 auto;
    border: 1px solid rgb(71, 71, 71);
    border-radius: 8px;
    overflow: hidden;
    padding: 0;
    background: #1212125a;
    text-shadow: 0 0 5px black;
    transition: 0.2s;
    p,
    .tech-stack {
      margin-left: 1em;
    }
    &:hover {
      background: #142d4e;
    }
  }
  .card header {
    h3 {
      border-top: 1px solid rgb(107, 106, 106);
      margin: 0;
      padding: 12px 1rem 0;
      font-size: 1.7rem;
      transition: 0.2s;
    }
  }
  .card-media {
    height: 220px;
    overflow: hidden;
    border-radius: 6px 6px 0 0;

    img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease-out;
    }
  }
  .thumbnail-fallback {
    width: 100%;
    height: 100%;
    background: var(--glass-bg);
    transition: transform 0.3s ease-out;
  }
  .card:hover {
    border: 1px solid var(--faint-border);
  }
  .card:hover .card-media img,
  .card:hover .card-media .thumbnail-fallback {
    transform: scale(1.05);
  }
  .card:hover header h3 {
    background: linear-gradient(
      to bottom,
      #4fa0f7 0%,
      #4893f5 40%,
      #8fd3ff 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-left: 1.5rem;
    text-shadow: none;
  }
  .card:hover .tech-stack li {
    background: var(--aero-blue);
  }

  .tech-stack {
    display: flex;
    list-style-type: none;
    justify-content: start;
    gap: 5px;
    margin-top: 6px;
    flex-wrap: wrap;

    li {
      border: 1px solid #dad9d97a;
      padding: 4px 12px;
      border-radius: 25px;
      background: var(--aero-black);
      font-weight: 300;
      display: flex;
      align-items: center;

      box-shadow: 0 3px 12px black;
    }
  }
  .tech-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;

    svg {
      color: currentColor;
    }
  }
  .card footer {
    margin-top: 16px;
    display: flex;
    justify-content: space-around;
    align-items: center;

    a {
      position: relative;
      color: white;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      border: 1px solid black;
      padding-block: 6px;
      border-radius: 0 0 5px 5px;
      background: var(--aero-black);
      z-index: 1;

      &::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 0 0 5px 5px;
        z-index: -1;
        background: var(--aero-blue);
        opacity: 0;
        transition: opacity 0.2s ease-out;
      }

      &:hover::after {
        opacity: 1;
      }
    }

    svg {
      height: 16px;
      aspect-ratio: 1;
      margin-left: 0;
    }
  }
</style>
