---
import * as Icons from "simple-icons";

const skills = [
  { label: "JavaScript", icon: Icons.siJavascript },
  { label: "TypeScript", icon: Icons.siTypescript },
  { label: "React", icon: Icons.siReact },
  { label: "Astro", icon: Icons.siAstro },
  { label: "Vue", icon: Icons.siVuedotjs },
  { label: "Tailwind CSS", icon: Icons.siTailwindcss },
  { label: "Node.js", icon: Icons.siNodedotjs },
  { label: "Python", icon: Icons.siPython },
  { label: "Git", icon: Icons.siGit },
  { label: "SQL", icon: Icons.siSqlite },
];
---

<section class="skills-section">
  <h2>Skills</h2>
  <div class="marquee-container">
    <div class="marquee">
      {
        skills.map((skill) => (
          <div class="skill-item">
            <svg
              class="skill-icon"
              role="img"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d={skill.icon.path} fill="currentColor" />
            </svg>
            <span>{skill.label}</span>
          </div>
        ))
      }
      {
        skills.map((skill) => (
          <div class="skill-item">
            <svg
              class="skill-icon"
              role="img"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d={skill.icon.path} fill="currentColor" />
            </svg>
            <span>{skill.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 4rem 2rem;
    text-align: center;
  }

  .skills-section h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
  }

  .marquee-container {
    overflow: hidden;
    background: linear-gradient(90deg, #313131, #202020, #313131);
    padding: 1rem 0;
  }

  .marquee {
    display: flex;
    animation: scroll 20s linear infinite;
    gap: 1rem;
  }

  .marquee:hover {
    animation-play-state: paused;
  }

  .skill-item {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    flex-shrink: 0;
    padding: 0.75rem 1.5rem;
    background: var(--aero-black);
    border-radius: 15px;
    color: white;
    font-weight: 500;
    white-space: nowrap;
    border: 1px solid var(--faint-border);
    box-shadow: 0 5px 5px rgb(24, 24, 24);
  }

  .skill-item span {
    color: white;
  }

  .skill-icon {
    color: white;
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
