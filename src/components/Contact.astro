---
const contactItems = [
  {
    label: "Email",
    value: "ruhlmirkojoel@gmail.com",
    href: "mailto:ruhlmirkojoel@gmail.com",
  },
  {
    label: "LinkedIn",
    value: "mirko-ruhl-730581200",
    href: "https://www.linkedin.com/in/mirko-ruhl-730581200",
  },
  {
    label: "GitHub",
    value: "github.com/RuhlMirko",
    href: "https://github.com/RuhlMirko",
  },
];
---

<section id="contact" class="contact" data-reveal>
  <h2 class="section-title">Contact</h2>

  <div class="contact-shell">
    <div class="contact-copy">
      <h3>Let's build something practical and polished.</h3>
      <p class="eyebrow">Open to freelance and full-time roles</p>
      <p class="lead">
        If you have a project in mind, need frontend support, or want to discuss
        a collaboration, I am happy to connect.
      </p>
      <p class="ps-tag">
        The fastest way to reach me is by email. I usually reply within one
        business day.
      </p>

      <div class="contact-actions">
        <a class="contact-btn primary" href="mailto:ruhlmirkojoel@gmail.com"
          >Send an email</a
        >
        <a
          class="contact-btn"
          href="https://www.linkedin.com/in/mirko-ruhl-730581200"
          target="_blank"
          rel="noreferrer"
        >
          Connect on LinkedIn
        </a>
      </div>
    </div>

    <aside class="contact-panel" aria-label="Contact details">
      <ul>
        {
          contactItems.map((item) => (
            <li>
              <p class="detail-label">{item.label}</p>
              <a
                href={item.href}
                target={item.href.startsWith("http") ? "_blank" : undefined}
                rel={item.href.startsWith("http") ? "noreferrer" : undefined}
              >
                {item.value}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M15 3h6v6" />
                  <path d="M10 14 21 3" />
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="availability">
        <p class="detail-label">Availability</p>
        <p>Available for remote collaboration across Europe and beyond.</p>
      </div>
    </aside>
  </div>
</section>

<style>
  .contact {
    padding-inline: clamp(0.75rem, 2vw, 1.25rem);
  }

  .contact-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.9fr);
    gap: 1.25rem;
    align-items: stretch;
  }

  .contact-copy,
  .contact-panel {
    border: 1px solid rgb(68, 68, 68);
    border-radius: 20px;
    background: rgba(18, 18, 18, 0.92);
    box-shadow:
      0 14px 30px rgba(0, 0, 0, 0.28),
      var(--inner-shadow);
    overflow: hidden;
  }

  .contact-copy {
    padding: clamp(1.5rem, 3vw, 2.4rem);
  }

  .eyebrow {
    width: 100%;
    display: inline-block;
    margin-block: 0.3rem;
    padding: 0.35rem 0.8rem;
    border: 1px solid rgba(190, 202, 217, 0.3);
    border-radius: 50px;
    background: var(--aero-green);
    color: #f3f7ff;
    font-family: "Jost", "Segoe UI", sans-serif;
    font-size: 0.88rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: center;
  }

  .contact-copy h3 {
    margin-bottom: 0.85rem;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: #f3f7ff;
    max-width: 24ch;
    text-align: center;
    text-wrap: pretty;
    line-height: 1.2;
  }

  .lead {
    font-size: clamp(1.12rem, 1.8vw, 1.28rem);
    line-height: 1.6;
    color: #f3f7ff;
    max-width: 42ch;
    margin-bottom: 0.85rem;
  }

  .ps-tag {
    font-style: italic;
    font-weight: 100;
    margin: 0 auto;
    width: fit-content;
  }

  .contact-copy p + p {
    margin-top: 0.8rem;
  }

  .contact-actions {
    margin-top: 1.35rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .contact-btn {
    position: relative;
    padding: 0.72rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 12px;
    color: #f7faff;
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.02em;
    background: var(--aero-black);
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .contact-btn.primary {
    border-color: rgba(143, 211, 255, 0.7);
    background: var(--aero-blue);
  }

  .contact-btn:hover,
  .contact-btn:focus-visible {
    transform: translateY(-1px);
    border-color: rgba(160, 218, 255, 0.8);
    box-shadow: 0 8px 14px rgba(0, 0, 0, 0.28);
    outline: none;
  }

  .contact-panel {
    padding: 1rem;
    background:
      linear-gradient(180deg, rgba(20, 43, 74, 0.82), rgba(18, 18, 18, 0.96)),
      var(--aero-black);
    display: grid;
    gap: 0.9rem;
  }

  .contact-panel ul {
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }

  .contact-panel li,
  .availability {
    border: 1px solid rgba(205, 220, 241, 0.24);
    border-radius: 16px;
    background: rgba(9, 12, 17, 0.58);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.22);
    padding: 0.95rem 1rem;
  }

  .detail-label {
    margin-bottom: 0.35rem;
    color: #f3f7ff;
    font-family: "Jost", "Segoe UI", sans-serif;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.82rem;
  }

  .contact-panel a {
    color: rgba(236, 242, 250, 0.92);
    text-decoration: none;
    word-break: break-word;
    svg {
      height: 16px;
      aspect-ratio: 1;
      margin-left: 2px;
      stroke: rgb(106, 180, 248);
    }
  }

  .contact-panel a:hover,
  .contact-panel a:focus-visible {
    color: #8fd3ff;
    outline: none;
  }

  .availability p:last-child {
    color: rgba(236, 242, 250, 0.9);
  }

  @media (max-width: 980px) {
    .contact-shell {
      grid-template-columns: 1fr;
    }

    .contact-copy h3,
    .lead {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .contact {
      padding-inline: 0.35rem;
    }

    .contact-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .contact-btn {
      text-align: center;
    }
  }
</style>
