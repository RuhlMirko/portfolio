---
import Cta from "../components/Cta.astro";
---

<section id="hero">
  <header>
    <h1>Mirko Joel Ruhl</h1>
    <h2>Full Stack Developer</h2>
  </header>
  <main data-reveal>
    <div class="hero-info">
      <div class="achievements">
        <p><span>4+</span><br />Years experience</p>
        <p><span>User</span><br />Experience first</p>
        <p><span>Scalable</span><br />Projects</p>
      </div>

      <p>Frontend ◦ Backend ◦ Designer. <br />Building friendly UX</p>

      <div class="hero-cta">
        <a class="cta" href="#projects">View Projects</a>
        <a href="/resume.pdf" download>Download resume</a>
        <a href="#contact">Contact</a>
      </div>
    </div>
    <Cta />
  </main>
</section>

<style>
  body {
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }
  h1 {
    font-size: 4rem;
    transition: 0.3s;
    width: fit-content;
    white-space: nowrap;
    margin: 0 auto;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-weight: 300;
    letter-spacing: 2px;
    font-size: 1.8rem;
    width: fit-content;
    /* text-shadow: 0 0 5px #105270; */
    background: #121212;
    padding: 0.2rem 2rem;
    margin: 0 auto 1rem;
    border: 1px solid var(--faint-border);
    box-shadow: 0 8px 1rem rgba(0, 0, 0, 0.623);
  }

  #hero header {
    animation: load-up 700ms ease-out both;
  }

  .hero-info {
    margin-right: 3rem;

    a {
      border: 1px solid rgb(133, 133, 133);
      color: white;
      padding: 1rem;
      text-decoration: none;
      border-radius: 15px;
      background: var(--aero-black);
      min-width: 120px;
      text-align: center;

      &:hover {
        background: var(--aero-blue);
      }
    }

    .cta {
      background: radial-gradient(rgb(0, 112, 216), rgb(0, 39, 168));
      /* background: var(--aero-blue); */
    }
  }

  .hero-cta {
    display: flex;
    justify-content: start;
    gap: 8px;
    margin-top: 1rem;
  }

  .achievements {
    display: flex;
    justify-content: space-between;
    gap: 5px;
    margin-bottom: 1rem;
    font-family: "Jost";

    p {
      border: 1px solid rgb(80, 80, 80);
      height: 100px;
      background: #202020;
      padding: 1rem;
      box-shadow: 0 5px 10px black;
      span {
        font-size: 2rem;
        margin: 6px 0;
      }
    }
  }

  section {
    padding-block: 6vh;

    margin-bottom: 0;
  }

  main {
    display: flex;
    justify-content: space-between;
    align-items: start;
    margin-top: 7rem;
  }

  #hero {
    margin: 20vh auto 10vh;
  }
  @keyframes load-up {
    0% {
      opacity: 0;
      transform: translateY(28px) scale(0.92);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>
