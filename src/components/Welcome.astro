---
import Cta from "../components/Cta.astro";
---

<section id="hero">
  <header>
    <h1>Mirko Joel Ruhl</h1>
    <h2>Full Stack Developer</h2>
  </header>
  <main data-reveal>
    <div class="hero-info">
      <div class="achievements">
        <p><span>4+</span><br />Years experience</p>
        <p><span>User</span><br />Experience first</p>
        <p><span>Scalable</span><br />Projects</p>
      </div>

      <p>
        Frontend ◦ Backend ◦ Designer. <br />Building excellent UX with
        JavaScript, TypeScript, Astro, React, Node.js, and a focus on clean,
        scalable interfaces.
      </p>

      <div class="hero-cta">
        <a class="cta" href="#projects">View Projects</a>
        <a href="/resume.pdf" download>Download resume</a>
        <a href="#contact">Contact</a>
      </div>
    </div>
    <Cta />
  </main>
</section>

<style>
  body {
    font-family: inherit;
  }
  h1 {
    transition: 0.3s;
    width: fit-content;
    white-space: nowrap;
    margin: 0 auto;
    margin-bottom: 0.75rem;
    letter-spacing: 0.12em;
  }

  h2 {
    font-weight: 400;
    letter-spacing: 0.18em;
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    width: fit-content;
    color: var(--text-primary);
    background: var(--aero-black);
    padding: 0.45rem 1.5rem;
    margin: 0 auto 1.25rem;
    border: 1px solid rgba(187, 197, 210, 0.32);
    border-radius: 999px;
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.35);
  }

  #hero header {
    animation: load-up 700ms ease-out both;
  }

  .hero-info {
    a {
      position: relative;
      z-index: 1;
      border: 1px solid rgb(133, 133, 133);
      color: white;
      padding: 1rem;
      text-decoration: none;
      border-radius: 15px;
      background: transparent;
      min-width: 120px;
      text-align: center;
      transition: transform 0.2s ease-out;
      box-shadow: 2px 5px 5px rgba(0, 0, 0, 0.548);
      overflow: hidden;

      &::before,
      &::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 15px;
        z-index: -1;
      }

      &::before {
        background: var(--aero-black);
      }

      &::after {
        background: var(--aero-blue);
        opacity: 0;
        transition: opacity 0.2s ease-out;
        filter: brightness(1.3);
      }

      &:hover {
        transform: translate(2px, 2px);
      }

      &:hover::after {
        opacity: 1;
      }
    }

    .cta {
      color: #000000;
      font-weight: 900;
      border-color: #838282;
      font-family: "Jost";
      letter-spacing: 1px;
      text-shadow: 0 0 12px #fff;
      &:hover {
        color: #fff;
      }
      &::before {
        background: var(--aero-white);
      }
    }
  }

  .hero-cta {
    display: flex;
    justify-content: start;
    gap: 8px;
    margin-top: 1.4rem;
  }

  .achievements {
    display: flex;
    justify-content: space-between;
    gap: 5px;
    margin-bottom: 1.25rem;
    font-family: "Jost";

    p {
      border: 1px solid rgb(80, 80, 80);
      min-height: 120px;
      background: #202020;
      padding: 1rem 0.9rem;
      /* box-shadow: 0 5px 10px black; */
      box-shadow: 0 12px 18px rgba(0, 0, 0, 0.55);
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.35rem;
      line-height: 1.25;
      overflow-wrap: anywhere;
      span {
        display: block;
        font-size: clamp(1.5rem, 4vw, 2rem);
        line-height: 1;
        margin: 0;
      }
    }
  }

  .hero-info > p {
    max-width: 60ch;
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.7;
    color: var(--text-primary);
  }

  section {
    padding-block: 6vh;

    margin-bottom: 0;
  }

  main {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 5rem;
    align-items: stretch;
    margin-top: 7rem;
  }

  @media (max-width: 980px) {
    main {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }
    h1 {
      text-shadow: 0 12px 12px rgba(0, 0, 0, 0.479);
    }
    h2 {
      font-size: 2rem;
      margin-top: 1.5rem;
    }
    .hero-info {
      margin: 0;
    }
    .achievements {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      width: 100%;
    }

    .achievements p {
      min-height: 132px;
    }

    .hero-cta a {
      width: 100%;
      padding-block: 1.5rem;
      font-size: 1.3rem;
    }

    .hero-cta {
      flex-direction: column;
      align-items: stretch;
    }
  }

  @media (max-width: 640px) {
    h1 {
      white-space: normal;
      text-align: center;
      letter-spacing: 0.08em;
    }

    h2 {
      width: min(100%, max-content);
      padding-inline: 1rem;
    }

    .achievements {
      grid-template-columns: 1fr;
      text-align: center;
      p {
        font-size: 5vw;
      }
    }
  }

  #hero {
    margin: 20vh auto 10vh;
  }
  @keyframes load-up {
    0% {
      opacity: 0;
      transform: translateY(28px) scale(0.92);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>
