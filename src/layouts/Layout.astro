<style is:global>
  :root {
    --faint-border: rgba(255, 255, 255, 0.459);
    --glass-bg: linear-gradient(
      160deg,
      #555454 4%,
      #414141 15%,
      rgba(34, 34, 34, 0.5) 50%,
      rgba(48, 48, 48, 0.3)
    );
    --glass-bg-secondary: linear-gradient(
      160deg,
      #cccbcb 10%,
      #7e7d7d 50%,
      #bdbcbc
    );
    --grid-size: 20px;
    --grid-line: rgba(255, 255, 255, 0.031);
    --aero-blue: linear-gradient(
      to bottom,
      #6e8dc3 0%,
      #6e8dc3 20%,
      #1d329d 35%,
      #1d329d 65%,
      #135197 80%,
      #2593c8 95%
    );
    --aero-black: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.35) 0,
      rgba(117, 117, 117, 0.35) 20%,
      rgba(0, 0, 0, 0.5) 35%,
      rgba(0, 0, 0, 0.5) 65%,
      rgba(27, 27, 27, 0.7) 80%,
      rgba(41, 41, 41, 0.5) 95%
    );
  }

  * {
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  html,
  body {
    width: 100%;
    height: 100%;
  }
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 40px;
  }
  section {
    margin-block: 8rem;
  }

  hr {
    border: none;
    border-top: 1px solid var(--faint-border);
    height: 0;
    margin-bottom: 1rem;
  }
  main {
    max-width: 1080px;
    margin: 0 auto;
  }
  body {
    color: white;
    background:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, #2b2b2b, #121212);
    background-size:
      var(--grid-size) var(--grid-size),
      var(--grid-size) var(--grid-size),
      100% 100%;
    background-attachment: fixed;
    font-family:
      "Nunito",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }
  h1,
  h2,
  h3 {
    font-family: "Segoe UI";
  }
  p {
    color: #e6e5e5;
    font-weight: 300;
  }
  h2 {
    font-size: 3rem;
    text-align: center;
    padding-bottom: 0.5rem;
  }
</style>

<script>
  // ######### SMOOTH SCROLL ######### //
  import Lenis from "lenis";
  import "lenis/dist/lenis.css";
  const lenis = new Lenis();
  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }

  requestAnimationFrame(raf);
</script>
