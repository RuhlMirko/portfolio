<style is:global>
  :root {
    --faint-border: rgba(255, 255, 255, 0.459);
    --glass-bg: linear-gradient(160deg, #414141 10%, #222 50%, #303030);
    --glass-bg-secondary: linear-gradient(
      160deg,
      #cccbcb 10%,
      #7e7d7d 50%,
      #bdbcbc
    );
    --grid-size: 20px;
    --grid-line: rgba(255, 255, 255, 0.031);
  }

  * {
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  html,
  body {
    width: 100%;
    height: 100%;
  }
  main {
    max-width: 1080px;
    margin: 0 auto;
  }
  body {
    color: white;
    background:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, #2b2b2b, #121212);
    background-size:
      var(--grid-size) var(--grid-size),
      var(--grid-size) var(--grid-size),
      100% 100%;
    background-attachment: fixed;
    font-family:
      "Nunito",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }
  a {
    border-radius: 6px;
  }
  h1,
  h2,
  h3 {
    font-family: "Jost", sans-serif;
  }
  p {
    color: #e6e5e5;
    font-weight: 300;
  }
</style>

<script>
  // ######### SMOOTH SCROLL ######### //
  import Lenis from "lenis";
  import "lenis/dist/lenis.css";
  const lenis = new Lenis({
    duration: 1.2, // Animation duration in seconds
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  });
  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }

  requestAnimationFrame(raf);
</script>
