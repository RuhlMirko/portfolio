<style is:global>
  :root {
    --faint-border: rgba(255, 255, 255, 0.459);
    --glass-bg: linear-gradient(
      160deg,
      #555454 4%,
      #414141 15%,
      #222 50%,
      #303030
    );
    --glass-bg-secondary: linear-gradient(
      160deg,
      #cccbcb 10%,
      #7e7d7d 50%,
      #bdbcbc
    );
    --grid-size: 20px;
    --grid-line: rgba(255, 255, 255, 0.031);
  }

  * {
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  html,
  body {
    width: 100%;
    height: 100%;
  }

  section {
    margin-block: 8rem;
  }

  hr {
    border: none;
    border-top: 1px solid var(--faint-border);
    height: 0;
    margin-bottom: 1rem;
  }
  main {
    max-width: 1080px;
    margin: 0 auto;
  }
  body {
    color: white;
    background:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, #2b2b2b, #121212);
    background-size:
      var(--grid-size) var(--grid-size),
      var(--grid-size) var(--grid-size),
      100% 100%;
    background-attachment: fixed;
    font-family:
      "Nunito",
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }
  a {
    border-radius: 6px;
  }
  h1,
  h2,
  h3 {
    font-family: "Segoe UI";
  }
  p {
    color: #e6e5e5;
    font-weight: 300;
  }

  .aero-black {
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.25) 0,
      rgba(117, 117, 117, 0.15) 20%,
      rgba(92, 92, 92, 0.15) 30%,
      rgba(0, 0, 0, 0.3) 70%,
      rgba(41, 41, 41, 0.3) 90%
    );

    box-shadow: 4px 4px 10px #111;
    border-radius: 5px;

    &:before {
      content: "";
      position: absolute;
      height: 24px;
      background: linear-gradient(
        to bottom,
        rgba(117, 117, 117, 0.7) 0,
        rgba(255, 255, 255, 0.1) 100%
      );
      top: 2px;
      right: 5%;
      border-radius: 5px;
      width: 90%;
      box-shadow: 0 5px 6px rgba(255, 255, 255, 0.1);
    }
  }
</style>

<script>
  // ######### SMOOTH SCROLL ######### //
  import Lenis from "lenis";
  import "lenis/dist/lenis.css";
  const lenis = new Lenis();
  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }

  requestAnimationFrame(raf);
</script>
